{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sapserver-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "SapPool": {
    "PoolSize": 3,
    "MaxQueueDepth": 50,
    "IdleTimeoutSeconds": 300,
    "HealthCheckIntervalSeconds": 60,
    "ReconnectDelayMs": 5000,
    "ServiceAccount": {
      "System": "<REDACTED>",
      "Client": "<REDACTED>",
      "SystemId": "<REDACTED>",
      "User": "<REDACTED>",
      "Password": "<REDACTED>",
      "Language": "EN"
    }
  },
  "Auth": {
    "JwtSecret": "",
    "JwtIssuer": "sql2005-bridge",
    "JwtAudience": "sap-server",
    "BypassPermissions": true
  },
  "AllowedOrigins": [
    "http://localhost:4000",
    "http://localhost:3000"
  ],
  "Urls": "http://0.0.0.0:5200;http://[::]:5200"
}