{"nodes": [{"id": "private_logistics", "label": "Logistics Nexus Page", "file_type": "code", "source_file": "private/logistics.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "cdn_jquery", "label": "jQuery 3.7.1", "file_type": "code", "source_file": "private/logistics.html", "source_location": null, "source_url": "https://code.jquery.com/jquery-3.7.1.min.js", "captured_at": null, "author": null, "contributor": null}, {"id": "cdn_datatables", "label": "DataTables 1.13.8", "file_type": "code", "source_file": "private/logistics.html", "source_location": null, "source_url": "https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js", "captured_at": null, "author": null, "contributor": null}, {"id": "cdn_chart_js", "label": "Chart.js 4.4.4", "file_type": "code", "source_file": "private/logistics.html", "source_location": null, "source_url": "https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js", "captured_at": null, "author": null, "contributor": null}, {"id": "private_logistics_shipment_creation_section", "label": "Shipment Creation Section", "file_type": "concept", "source_file": "private/logistics.html", "source_location": "lines 52-102", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Groups tiles for building shipments from completed picksheets: Open Deliveries, Awaiting Booking, Customs Documents, Customer Specifics. Visible to LOG_VIEW but write actions require LOG_PLANNING, separating read visibility from planning authority."}, {"id": "private_logistics_shipment_monitoring_section", "label": "Shipment Monitoring Section", "file_type": "concept", "source_file": "private/logistics.html", "source_location": "lines 104-165", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tracks shipment lifecycle after creation: Awaiting Collection, In Transit, Completed Shipments, Search, and a planned Inbound Log (marked SOON)."}, {"id": "private_logistics_material_planning_section", "label": "Material Planning Section", "file_type": "concept", "source_file": "private/logistics.html", "source_location": "lines 167-261", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "MRP-facing tiles: live stock turns/valuation tables, stock value overview and price-band breakdown, valuation class change (moves stock to an order, changes class in SAP, moves it back), and 13-month consumption history vs demand forecast. Purchase Orders, Schedule Agreements and MRP tiles are placeholders (SOON)."}, {"id": "private_logistics_admin_section", "label": "Logistics Admin Section", "file_type": "concept", "source_file": "private/logistics.html", "source_location": "lines 263-324", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Admin-badged maintenance and analytics tiles: Freight Spend dashboard, Unprocessed Costs awaiting SAP MIGO processing, and master-data maintenance for pallets, packaging and destinations."}, {"id": "private_logistics_permission_gating", "label": "Tile Permission Gating (data-permission)", "file_type": "rationale", "source_file": "private/logistics.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each pn-section carries a data-permission attribute (LOG_VIEW, LOG_MRP, LOG_ADMIN) so client-side JS can show/hide entire tile groups per user permission; a comment notes write actions in Shipment Creation additionally require LOG_PLANNING."}, {"id": "private_logistics_log_view", "label": "LOG_VIEW Permission", "file_type": "concept", "source_file": "private/logistics.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "private_logistics_log_mrp", "label": "LOG_MRP Permission", "file_type": "concept", "source_file": "private/logistics.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "private_logistics_log_admin", "label": "LOG_ADMIN Permission", "file_type": "concept", "source_file": "private/logistics.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "private_logistics_log_planning", "label": "LOG_PLANNING Permission", "file_type": "concept", "source_file": "private/logistics.html", "source_location": "line 52 comment", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "private_logistics_result_panel", "label": "Result Panel (tile drill-down view)", "file_type": "concept", "source_file": "private/logistics.html", "source_location": "lines 328-341", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hidden result-section swapped in place of the tile grid when a tile function runs; toolbar exposes backToTiles() and exportResultCSV() handlers plus row-count badge, so all tile functions share one output surface instead of separate pages."}], "edges": [{"source": "private_logistics", "target": "css_production_nexus", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "private/logistics.html", "source_location": "line 9", "weight": 1.0}, {"source": "private_logistics", "target": "css_logistics", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "private/logistics.html", "source_location": "line 10", "weight": 1.0}, {"source": "private_logistics", "target": "css_nexus_common", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "private/logistics.html", "source_location": "line 11", "weight": 1.0}, {"source": "private_logistics", "target": "css_notifications", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "private/logistics.html", "source_loca