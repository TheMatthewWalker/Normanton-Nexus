# ── SAP integration ───────────────────────────────────────────────────────────
SAP_SERVER_SECRET=your-sap-server-secret-here

# ── Kuehne+Nagel Freight Booking API ─────────────────────────────────────────
# Full URL of the KN booking endpoint (e.g. https://api.kuehne-nagel.com/...)
KN_API_URL=https://api.kuehne-nagel.com/bookings/v1

# Mandatory KN administrative credentials (provided by KN)
KN_CUSTOMER_ID=CustomerBranchWest
KN_CUSTOMER_KEY=your-kn-customer-key-here

# Base64 client secret used to obtain an OAuth access token (client_credentials
# grant against https://portal.api.kuehne-nagel.com/oauth2/token). Shared by
# both the booking API above and the Document Management API below.
KN_SECRET_64=your-kn-base64-client-secret-here

# ── Kuehne+Nagel Shipment Document Management API ────────────────────────────
# Separate service from the booking API above, but authenticates with the
# same OAuth client-credentials token (KN_SECRET_64 above). Defaults to the
# URL in KN's published swagger, so this only needs setting if KN ever
# versions the path.
KN_DOCUMENTS_API_URL=https://gateway.api.kuehne-nagel.com/transport/execution/documentation/shipment/v2

# ── ClearPort Customs Declaration API ────────────────────────────────────────
# Base URL — defaults to https://api.clear-port.com if not set
CLEARPORT_API_URL=https://api.clear-port.com

# Bearer token issued by ClearPort (used in Authorization header)
CLEARPORT_API_TOKEN=your-clearport-bearer-token-here
